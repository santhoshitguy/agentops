# ============================================================
# AgentOps Lite — Apache .htaccess for Shared PHP Hosting
# Enables Angular SPA routing on standard Apache servers
# ============================================================

# Enable mod_rewrite
Options -MultiViews
RewriteEngine On

# ── 1. Serve static assets directly (extension-based — reliable on all hosts) ─
RewriteRule ^.+\.(js|mjs|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|map|json|txt|xml|webmanifest)$ - [L,NC]

# ── 2. Route all Angular paths to index.html ─────────────────
# (Handles /dashboard, /workflow-canvas, /agent-monitor, etc.)
RewriteRule ^ index.html [L]

# ── 3. Security headers ──────────────────────────────────────
<IfModule mod_headers.c>
    # Prevent MIME-type sniffing
    Header set X-Content-Type-Options "nosniff"

    # Prevent clickjacking
    Header set X-Frame-Options "SAMEORIGIN"

    # Enable XSS protection
    Header set X-XSS-Protection "1; mode=block"

    # Referrer policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── 4. Enable compression (speeds up load time) ──────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml
    AddOutputFilterByType DEFLATE text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── 5. Cache-Control for hashed JS/CSS chunks ────────────────
# Angular output-hashes all chunk filenames — safe to cache 1 year
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML — never cache (always fetch fresh index.html)
    <FilesMatch "\.html$">
        ExpiresDefault "access plus 0 seconds"
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>

    # Hashed JS/CSS chunks — cache 1 year
    <FilesMatch "\.(js|css|woff2?|ttf|eot|otf)$">
        ExpiresDefault "access plus 1 year"
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Images & fonts — cache 30 days
    <FilesMatch "\.(ico|jpg|jpeg|png|gif|svg|webp)$">
        ExpiresDefault "access plus 30 days"
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>

# ── 6. Force HTTPS (uncomment once SSL cert is active) ───────
# <IfModule mod_rewrite.c>
#     RewriteCond %{HTTPS} off
#     RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
# </IfModule>
