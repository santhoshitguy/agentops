{
  "name": "agentops-lite",
  "version": "1.0.0",
  "description": "AgentOps Lite — Angular 21 AI Agent Operations Dashboard Template. Monitor, orchestrate, debug and optimize autonomous AI agents with a dark neon enterprise dashboard.",
  "keywords": [
    "angular",
    "angular-21",
    "admin-template",
    "ai-dashboard",
    "agent-monitoring",
    "llm",
    "dashboard-template",
    "dark-theme",
    "angular-signals",
    "standalone-components",
    "typescript",
    "tailwindcss",
    "saas-template",
    "enterprise-dashboard",
    "ai-ops"
  ],
  "author": "AgentOps Lite",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:demo": "ng build --configuration themeforest",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "mock-server": "cd mock-server && npm start",
    "mock-server:dev": "cd mock-server && npm run dev"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.1.3",
    "@angular/cdk": "^21.1.3",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@swimlane/ngx-charts": "^23.1.0",
    "@swimlane/ngx-graph": "^11.0.0",
    "chart.js": "^4.5.1",
    "d3": "^7.9.0",
    "lucide-angular": "^0.563.0",
    "ng2-charts": "^8.0.0",
    "ngx-charts": "^3.0.2",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.1",
    "@angular/cli": "^21.0.1",
    "@angular/compiler-cli": "^21.0.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/d3": "^7.4.3",
    "angular-eslint": "21.2.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.2",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.50.1",
    "vitest": "^4.0.8"
  }
}